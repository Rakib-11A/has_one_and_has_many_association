<%= form_with(model: student, local: true, class: "max-w-xl mx-auto bg-white p-6 rounded-xl shadow space-y-6") do |form| %>
  <% if student.errors.any? %>
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded">
      <strong><%= pluralize(student.errors.count, "error") %> found:</strong>
      <ul class="mt-2 list-disc list-inside">
        <% student.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_field :name, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <div>
    <%= form.label :school_class_id, "Class", class: "block text-sm font-medium text-gray-700" %>
    <%= form.collection_select :school_class_id, SchoolClass.all, :id, :name, prompt: "Select a class", class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <div class="flex justify-end space-x-4">
    <%= link_to "Cancel", students_path, class: "px-4 py-2 rounded border border-gray-300 text-gray-700 hover:bg-gray-100" %>
    <%= form.submit class: "px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700" %>
  </div>
<% end %>
